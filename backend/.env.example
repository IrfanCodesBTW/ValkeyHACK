# Backend HTTP port
PORT=4000

# Frontend origin allowed by CORS
FRONTEND_ORIGIN=http://localhost:3000

# Valkey connection string
VALKEY_URL=redis://localhost:6379

# Allow an in-memory store only for local tests when Valkey is unavailable
ALLOW_MEMORY_STORE=false

# Cookie/session settings
SESSION_COOKIE_NAME=valkey_sid
SESSION_TTL_SECONDS=86400
COOKIE_SECURE=false

# Optional LLM keys. Leave blank to use deterministic fallbacks.
GEMINI_API_KEY=
GROQ_API_KEY=

# Rate limits
AUTH_LOGIN_LIMIT=5
AUTH_LOGIN_WINDOW_SECONDS=900
SEARCH_LIMIT=60
SEARCH_WINDOW_SECONDS=60
CHECKOUT_LIMIT=10
CHECKOUT_WINDOW_SECONDS=60
RECOMMENDATIONS_LIMIT=60
RECOMMENDATIONS_WINDOW_SECONDS=60
