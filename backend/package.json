{
  "name": "valkey-ecommerce-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Valkey-powered e-commerce demo API",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node src/seed/runSeed.js",
    "test": "cross-env NODE_ENV=test ALLOW_MEMORY_STORE=true jest --runInBand",
